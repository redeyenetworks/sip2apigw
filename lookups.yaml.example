# Area ID to speech-ready name mapping.
# Edit this file to add/change/remove area mappings without code changes.
# Use phonetic spelling for TTS clarity where needed.
areas:
  710: "3rd Floor... Cardiac Step-Down..."
  711: "2nd Floor... Orthopedics..."
  712: "2nd Floor... Med Surge..."
  713: "Step-Down B..."
  714: "3rd Floor... Med Surge..."
