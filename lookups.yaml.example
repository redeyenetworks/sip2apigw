  798: "Pediatrics South..."
  799: "2nd Floor... O.B..."
# Default area name when area ID is not found in the table above.
default_area: "Unknown Area."

# Call purpose substitutions.
# Keys are substrings searched for in the SIP display name.
# Values are the speech-ready substitution.
# Order matters: first match wins.
call_purposes:
  "Blue": "Code Blue"
  "RRT": "Rapid Response Team"
  "Pink": "Code Pink"

# Default call purpose when no match is found.  Default to most critical to be safe.
default_purpose: "Code Blue"

# Room-only lookups (fallback when no area*room combo match exists).
# All specific room overrides are in the area_rooms section below.
rooms: {}

# Area+Room combo overrides.
# Used when the same room number exists in multiple areas but needs
# different spoken names. Format: "area*room": "name"
# These take priority over the rooms table above.
